{
  "name": "react-advanced-state-hook",
  "version": "1.0.5",
  "description": "A React hook that extends useState with persistence, debouncing, and advanced cross-component/tab sync.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "rm -rf dist && babel src --out-dir dist --extensions \".js,.jsx\" --ignore \"src/example/**\""
  },
  "keywords": [
    "react",
    "hook",
    "useState",
    "persistence",
    "localStorage",
    "sessionStorage",
    "debounce",
    "zustand",
    "context",
    "cross-tab"
  ],
  "author": "Dr. Burkhard Heisen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heisenware/react-advanced-state-hook.git"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.17.0",
    "@babel/core": "^7.17.0",
    "@babel/preset-env": "^7.17.0",
    "@babel/preset-react": "^7.17.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "babel-jest": "^29.7.0",
    "baseline-browser-mapping": "^2.10.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(js|jsx)$": "babel-jest"
    }
  }
}